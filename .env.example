# Copy this file to .env.local in the project root (same folder as package.json).
# Next.js reads .env.local automatically — it does NOT load .env.example at runtime.
#
# In Mailjet: Account → API Key Management → create a key pair (Public Key = MAILJET_API_KEY, Secret Key = MAILJET_API_SECRET).

MAILJET_API_KEY=your_mailjet_public_api_key
MAILJET_API_SECRET=your_mailjet_secret_key
MAILJET_SENDER_EMAIL=madhusudhan.timalsina@smartsarks.com
MAILJET_SENDER_NAME=Madhusudan Timalsina
CONTACT_TO_EMAIL=madhusudhan.timalsina@smartsarks.com
